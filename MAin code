<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Course Intelligence App</title>

<style>
body {
    background: #0f172a;
    color: #f8fafc;
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
    margin: 0;
}

.app {
    width: 360px;
    height: 640px;
    background: #020617;
    border-radius: 25px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    display: flex;
    flex-direction: column;
    border: 1px solid #334155;
}

.header {
    padding: 15px;
    text-align: center;
    background: #1e293b;
    font-weight: bold;
    font-size: 1.1rem;
    border-bottom: 1px solid #334155;
}

.screen {
    flex: 1;
    overflow-y: auto;
    padding: 15px;
    display: none;
}

.active {
    display: flex;
    flex-direction: column;
}

input, textarea, button {
    width: 100%;
    padding: 12px;
    margin: 6px 0;
    border-radius: 8px;
    border: 1px solid #334155;
    background: #1e293b;
    color: white;
    box-sizing: border-box;
    font-family: inherit;
}

input::placeholder, textarea::placeholder {
    color: #94a3b8;
}

input:focus, textarea:focus {
    outline: 2px solid #22c55e;
    border-color: transparent;
}

button {
    background: #22c55e;
    color: white;
    font-weight: bold;
    cursor: pointer;
    border: none;
    transition: background 0.2s;
}

button:hover {
    background: #16a34a;
}

.card {
    background: #1e293b;
    padding: 14px;
    margin: 8px 0;
    border-radius: 12px;
    border: 1px solid #334155;
}

.card h3 {
    margin: 0 0 5px 0;
}

.nav {
    display: flex;
    background: #1e293b;
    border-top: 1px solid #334155;
}

.nav button {
    flex: 1;
    background: none;
    color: #94a3b8;
    padding: 15px;
    margin: 0;
    border-radius: 0;
    font-size: 1.2rem;
}

.nav button.active-tab {
    color: #22c55e;
    background: #0f172a;
}

.bar-container {
    background: #334155;
    border-radius: 5px;
    height: 8px;
    width: 100%;
    margin: 8px 0;
    overflow: hidden;
}

.bar {
    height: 100%;
    border-radius: 5px;
    transition: width 0.3s ease;
}

.action-btns {
    display: flex;
    gap: 8px;
    margin-top: 10px;
}

.action-btns button {
    padding: 8px;
    font-size: 0.85rem;
    margin: 0;
}

.btn-del {
    background: #ef4444;
}
.btn-del:hover {
    background: #dc2626;
}
</style>
</head>

<body>

<div class="app">

<div class="header">📊 Course Intelligence</div>

<!-- HOME -->
<div class="screen active" id="home">
    <input id="course" placeholder="Course Code (e.g., CS101)">
    <input id="difficulty" type="number" min="1" max="5" placeholder="Difficulty (1-5)">
    <input id="workload" type="number" min="1" max="5" placeholder="Workload (1-5)">
    <input id="confidence" type="number" min="1" max="5" placeholder="Your Confidence Level (1-5)">
    <textarea id="comment" placeholder="Share advice or tips..."></textarea>
    <button onclick="addCourse()">Add Course</button>
</div>

<!-- COURSES -->
<div class="screen" id="courses"></div>

<!-- DASHBOARD -->
<div class="screen" id="dashboard"></div>

<!-- NAV -->
<div class="nav">
    <button id="btn-home" class="active-tab" onclick="show('home')">🏠</button>
    <button id="btn-courses" onclick="show('courses')">📚</button>
    <button id="btn-dashboard" onclick="show('dashboard')">📊</button>
</div>

</div>

<script>
let data = JSON.parse(localStorage.getItem("courses")) || [];

function show(id) {
    document.querySelectorAll(".screen").forEach(s => s.classList.remove("active"));
    document.querySelectorAll(".nav button").forEach(b => b.classList.remove("active-tab"));
    
    document.getElementById(id).classList.add("active");
    document.getElementById("btn-" + id).classList.add("active-tab");
    render();
}

function sanitize(text) {
    const div = document.createElement('div');
    div.innerText = text;
    return div.innerHTML;
}

function getLevel(score) {
    if (score >= 3.5) return ["✅ EASY", "#22c55e"];
    if (score >= 2.2) return ["⚠️ MEDIUM", "#f59e0b"];
    return ["🔥 HARD", "#ef4444"];
}

function addCourse() {
    const courseInput = document.getElementById("course");
    const diffInput = document.getElementById("difficulty");
    const workInput = document.getElementById("workload");
    const confInput = document.getElementById("confidence");
    const commInput = document.getElementById("comment");

    let c = sanitize(courseInput.value.trim());
    let d = +diffInput.value;
    let w = +workInput.value;
    let conf = +confInput.value;
    let com = sanitize(commInput.value.trim());

    if (!c || !d || !w || !conf) return alert("Please fill out all rating metrics!");
    if (d < 1 || d > 5 || w < 1 || w > 5 || conf < 1 || conf > 5) {
        return alert("Metrics must be between 1 and 5");
    }

    let score = (conf + (6 - d) + (6 - w)) / 3;
    let [level, color] = getLevel(score);

    data.push({
        id: Date.now(),
        c, d, w, conf, com, level, color, score, likes: 0
    });

    localStorage.setItem("courses", JSON.stringify(data));
    
    courseInput.value = "";
    diffInput.value = "";
    workInput.value = "";
    confInput.value = "";
    commInput.value = "";

    show('courses');
}

function render() {
    let courseHTML = "";
    if(data.length === 0) {
        courseHTML = `<p style="text-align:center; color:#64748b; margin-top:40px;">No reviews added yet.</p>`;
    }
    
    data.forEach(x => {
        let stressPercent = ((x.d + x.w) / 10) * 100;

        courseHTML += `
        <div class="card">
            <h3 style="display:flex; justify-content:space-between; margin:0;">
                <span>${x.c}</span>
                <span style="color:${x.color}; font-size:0.9rem;">${x.level}</span>
            </h3>
            <div style="font-size:0.8rem; color:#94a3b8; margin-top:8px;">Workload & Difficulty Intensity:</div>
            <div class="bar-container">
                <div class="bar" style="width:${stressPercent}%; background:${x.color};"></div>
            </div>
            <p style="font-size:0.9rem; margin:8px 0; color:#cbd5e1;">${x.com || "<em>No specific advice left.</em>"}</p>
            <div style="font-size:0.85rem; color:#94a3b8; margin-bottom:5px;">👍 ${x.likes} likes</div>
            <div class="action-btns">
                <button onclick="like(${x.id}, event)">Like Review</button>
                <button class="btn-del" onclick="del(${x.id}, event)">Delete</button>
            </div>
        </div>`;
    });
    document.getElementById("courses").innerHTML = courseHTML;

    let total = data.length;
    let hard = data.filter(x => x.level.includes("HARD")).length;
    let medium = data.filter(x => x.level.includes("MEDIUM")).length;
    let easy = data.filter(x => x.level.includes("EASY")).length;

    document.getElementById("dashboard").innerHTML = `
        <div class="card">
            <h3 style="border-bottom:1px solid #334155; padding-bottom:8px; margin-bottom:12px;">Global Breakdown</h3>
            <p style="display:flex; justify-content:space-between;"><span>Total Logs:</span> <strong>${total}</strong></p>
            <p style="display:flex; justify-content:space-between; color:#ef4444;"><span>🔥 Hard:</span> <strong>${hard}</strong></p>
            <p style="display:flex; justify-content:space-between; color:#f59e0b;"><span>⚠️ Medium:</span> <strong>${medium}</strong></p>
            <p style="display:flex; justify-content:space-between; color:#22c55e;"><span>✅ Easy:</span> <strong>${easy}</strong></p>
        </div>
    `;
}

function like(id, event){
    event.stopPropagation();
    data = data.map(x => {
        if(x.id === id) x.likes++;
        return x;
    });
    localStorage.setItem("courses", JSON.stringify(data));
    render();
}

function del(id, event){
    event.stopPropagation();
    data = data.filter(x => x.id !== id);
    localStorage.setItem("courses", JSON.stringify(data));
    render();
}

render();
</script>

</body>
</html>
